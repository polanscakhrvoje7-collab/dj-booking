# ─────────────────────────────────────────────────────────────────────────────
# Google Calendar Integration
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO SET UP:
#
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or select an existing one)
# 3. Enable the "Google Calendar API" for the project
# 4. Go to "IAM & Admin" → "Service Accounts" → "Create Service Account"
# 5. Give it a name (e.g. "dj-booking-service") and click "Done"
# 6. Click the service account → "Keys" tab → "Add Key" → "Create new key" → JSON
# 7. Download the JSON key file
# 8. From the JSON file, copy:
#    - "client_email"  → GOOGLE_SERVICE_ACCOUNT_EMAIL
#    - "private_key"   → GOOGLE_PRIVATE_KEY  (keep the \n characters — do NOT expand them)
#
# 9. In Google Calendar:
#    - Open the calendar you want bookings on
#    - Go to Settings → Share with specific people
#    - Add the service account email with "Make changes to events" permission
#    - Copy the Calendar ID (looks like: abc123@group.calendar.google.com or your Gmail)
#    - Set it as GOOGLE_CALENDAR_ID
#
# ─────────────────────────────────────────────────────────────────────────────

GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"

# Keep \n as literal \n — Next.js will handle them correctly
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# Use "primary" to write to the default calendar, or paste a specific calendar ID
GOOGLE_CALENDAR_ID="primary"

# Timezone for calendar events (IANA format)
GOOGLE_CALENDAR_TIMEZONE="Europe/Zagreb"

# ─────────────────────────────────────────────────────────────────────────────
# Email (Gmail App Password)
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO SET UP:
# 1. Go to myaccount.google.com → Security → 2-Step Verification (must be ON)
# 2. Search for "App Passwords" → Create one for "Mail"
# 3. Copy the 16-character password below
#
GMAIL_USER="polanscakhrvoje@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"

# Any long random string — used to sign approval links
BOOKING_SECRET="change-me-to-something-random-and-long"

# Your production URL (used to build approve links in emails)
NEXT_PUBLIC_BASE_URL="https://your-domain.com"
